<?xml version="1.0" encoding="utf-8"?>
<extension type="template" client="site">
	<name>Html56K</name>
	<version>6.3.0</version>
	<creationDate>March 2026</creationDate>
	<author>56K Agency</author>
	<authorEmail>assistenza@56k.agency</authorEmail>
	<authorUrl>https://www.56k.agency</authorUrl>
	<copyright>Copyright (C) 2026 56K s.r.l. - All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<description>TPL_HTML56K_XML_DESCRIPTION</description>
	<namespace>Agency56k\Template\Html56k</namespace>
	<files>
		<folder>css</folder>
		<folder>html</folder>
		<folder>images</folder>
		<folder>js</folder>		
		<folder>language</folder>
		<folder>scss</folder>
		<folder>fonts</folder>
		<folder>libraries</folder>
		<folder>src</folder>
		<folder>cache</folder>
		<filename>index.php</filename>
		<filename>template.php</filename>
		<filename>error.php</filename>
		<filename>component.php</filename>
		<filename>joomla.asset.json</filename>
		<filename>templateDetails.xml</filename>
		<filename>template_preview.png</filename>
		<filename>template_thumbnail.png</filename>
	</files>

	<positions>
		<position>top</position>
		<position>logo</position>
		<position>menu</position>
		<position>payoff</position>
		<position>section-top</position>
		<position>left</position>
		<position>center-top</position>
		<position>center-bottom</position>
		<position>right</position>
		<position>section-bottom</position>
		<position>footer</position>
		<position>copyright</position>
		<position>debug</position>
	</positions>
		
	<languages folder="language">
		<language tag="it-IT">it-IT/it-IT.tpl_html56k.ini</language>
		<language tag="it-IT">it-IT/it-IT.tpl_html56k.sys.ini</language>
		<language tag="en-GB">en-GB/en-GB.tpl_html56k.ini</language>
		<language tag="en-GB">en-GB/en-GB.tpl_html56k.sys.ini</language>
	</languages>
		
	<config>
		<fields name="params">
			<fieldset name="template" label="TPL_HTML56K_FIELDSET_TEMPLATE_LABEL">
				<field
					name="mode"
					type="radio"
					layout="joomla.form.field.radio.switcher"
					label="TPL_HTML56K_MODE_LABEL"
					description="TPL_HTML56K_MODE_DESC"
					default="0"
					>
					<option value="0">TPL_HTML56K_MODE_PRODUCTION</option>
					<option value="1">TPL_HTML56K_MODE_DEVELOPMENT</option>
				</field>
				<field
					name="browserupgrade"
					type="radio"
					layout="joomla.form.field.radio.switcher"
					label="TPL_HTML56K_BROWSERUPGRADE_LABEL"
					description="TPL_HTML56K_BROWSERUPGRADE_DESC"
					default="0"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field 
					name="showcomponent"
					type="radio"
					layout="joomla.form.field.radio.switcher"
					default="1"
					label="TPL_HTML56K_SHOWCOMPONENT_LABEL" 
					description="TPL_HTML56K_SHOWCOMPONENT_DESC">
					<option value="1">JYES</option>
					<option	value="0">JNO</option>
				</field>
				<field
					name="font_preload"
					type="radio"
					layout="joomla.form.field.radio.switcher"
					label="TPL_HTML56K_FONT_PRELOAD_LABEL"
					description="TPL_HTML56K_FONT_PRELOAD_DESC"
					default="1"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field
					name="lazy_loading"
					type="radio"
					layout="joomla.form.field.radio.switcher"
					label="TPL_HTML56K_LAZY_LOADING_LABEL"
					description="TPL_HTML56K_LAZY_LOADING_DESC"
					default="1"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field
					name="critical_css"
					type="radio"
					layout="joomla.form.field.radio.switcher"
					label="TPL_HTML56K_CRITICAL_CSS_LABEL"
					description="TPL_HTML56K_CRITICAL_CSS_DESC"
					default="0"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field
					name="critical_css_lifetime"
					type="number"
					label="TPL_HTML56K_CRITICAL_CSS_LIFETIME_LABEL"
					description="TPL_HTML56K_CRITICAL_CSS_LIFETIME_DESC"
					default="86400"
					min="0"
					max="604800"
				/>
			</fieldset>
			
			<fieldset name="customcode" label="TPL_HTML56K_FIELDSET_CUSTOMCODE_LABEL">
				<field name="after_head_open"
					type="textarea"
					label="TPL_HTML56K_AFTER_HEAD_OPEN_LABEL"
					description="TPL_HTML56K_AFTER_HEAD_OPEN_DESC"
					filter="raw"
					rows="5"
					cols="50" />
				<field name="before_head_close"
					type="textarea"
					label="TPL_HTML56K_BEFORE_HEAD_CLOSE_LABEL"
					description="TPL_HTML56K_BEFORE_HEAD_CLOSE_DESC"
					filter="raw"
					rows="5"
					cols="50" />
				<field name="after_body_open"
					type="textarea"
					label="TPL_HTML56K_AFTER_BODY_OPEN_LABEL"
					description="TPL_HTML56K_AFTER_BODY_OPEN_DESC"
					filter="raw"
					rows="5"
					cols="50" />
				<field name="before_body_close"
					type="textarea"
					label="TPL_HTML56K_BEFORE_BODY_CLOSE_LABEL"
					description="TPL_HTML56K_BEFORE_BODY_CLOSE_DESC"
					filter="raw"
					rows="5"
					cols="50" />
				<field name="favicon_code"
					type="textarea"
					label="TPL_HTML56K_FAVICON_CODE_LABEL"
					description="TPL_HTML56K_FAVICON_CODE_DESC"
					filter="raw"
					rows="5"
					cols="50" />
			</fieldset>
		</fields>
	</config>	
</extension>
